{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenySecretsManagerDeletion",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:DeleteSecret",
        "secretsmanager:CancelRotateSecret"
      ],
      "Resource": "*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalARN": [
            "arn:aws:iam::*:role/forge-break-glass-*"
          ]
        }
      }
    }
  ]
}
