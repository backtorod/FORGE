{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyCreateInternetGateway",
      "Effect": "Deny",
      "Action": [
        "ec2:AttachInternetGateway",
        "ec2:CreateInternetGateway"
      ],
      "Resource": "*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalARN": [
            "arn:aws:iam::*:role/forge-network-admin-*"
          ]
        }
      }
    },
    {
      "Sid": "DenyPublicElasticIP",
      "Effect": "Deny",
      "Action": "ec2:AllocateAddress",
      "Resource": "*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalARN": [
            "arn:aws:iam::*:role/forge-network-admin-*"
          ]
        }
      }
    }
  ]
}
