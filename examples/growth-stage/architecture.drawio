        <mxCell id="p1-e-sub-pub-app" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#82b366;" edge="1" parent="1" source="p1-sub-pub1" target="p1-sub-app1"><mxGeometry relative="1" as="geometry" /></mxCell>
