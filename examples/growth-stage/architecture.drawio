        <mxCell id="p1-tgw" value="&lt;b&gt;module.transit_gateway&lt;/b&gt;&#xa;Transit Gateway&#xa;─────────────────&#xa;• Hub for VPC attachment&#xa;• Cross-account routing&#xa;• BGP ASN managed&#xa;• RAM shared to Org&#xa;• Wired to primary VPC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
