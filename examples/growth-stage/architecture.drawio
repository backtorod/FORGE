        <mxCell id="p1-e-org-scp"     style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#6c8ebf;" edge="1" parent="1" source="p1-mod-org"  target="p1-mod-scp"><mxGeometry relative="1" as="geometry" /></mxCell>
