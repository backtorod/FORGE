  <!-- ======================================================================
       PAGE 2 — Security, Compliance & Drift Remediation
  ====================================================================== -->
  <diagram name="Page 2 — Security, Compliance &amp; Drift Remediation" id="growth-p2">
    <mxGraphModel dx="1920" dy="1080" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="p2-title" value="FORGE — Growth-Stage Architecture · Page 2 of 2: Security, Compliance &amp; Drift Remediation&#xa;50–500 Employees · SOC 2 Type II + HIPAA · AWS Config Aggregator · Macie · WAFv2" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=17;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="350" y="15" width="1200" height="50" as="geometry" />
        </mxCell>

        <!-- Cross-reference to Page 1 -->
        <mxCell id="p2-xref" value="← See Page 1 for: Foundation · Multi-Region Network · Identity / SCIM · Encryption" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;fontSize=10;fontStyle=3;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="58" width="980" height="22" as="geometry" />
        </mxCell>

        <!-- ORG BOUNDARY -->
        <mxCell id="p2-org" value="AWS Organization" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud_alt;strokeColor=#232F3E;fillColor=#FFFFFF;verticalAlign=top;align=center;spacingTop=25;fontStyle=1;fontSize=13;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="40" y="82" width="1840" height="910" as="geometry" />
        </mxCell>

        <!-- ==========================================================
             LEFT COLUMN (x=60, w=1130)
        ========================================================== -->

        <!-- SECURITY LAYER  y=90, h=325 -->
        <mxCell id="p2-security" value="SECURITY LAYER" style="swimlane;startSize=28;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;fontColor=#4d0000;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="1130" height="325" as="geometry" />
        </mxCell>
        <mxCell id="p2-gd" value="&lt;b&gt;module.guardduty&lt;/b&gt;&#xa;GuardDuty + SNS Alerts&#xa;─────────────────&#xa;• GuardDuty org-wide delegate&#xa;• Findings → EventBridge&#xa;• SNS topic (KMS-encrypted)&#xa;• Email subscriptions&#xa;• Audit account centralized&#xa;• alert_email variable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="126" width="210" height="175" as="geometry" />
        </mxCell>
        <mxCell id="p2-sh" value="&lt;b&gt;module.security_hub&lt;/b&gt;&#xa;Security Hub — Dual Standard&#xa;─────────────────&#xa;• SOC 2 (CIS + custom)&#xa;• HIPAA (new in growth)&#xa;• Org-wide aggregation&#xa;• Findings normalized&#xa;• Delegated to audit account&#xa;• Inspector + Macie feed in" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="126" width="215" height="175" as="geometry" />
        </mxCell>
        <mxCell id="p2-inspector" value="&lt;b&gt;module.inspector&lt;/b&gt;&#xa;Amazon Inspector v2&#xa;─────────────────&#xa;• EC2 + ECR + Lambda scan&#xa;• CVE vulnerability scanning&#xa;• All workload accounts&#xa;• Delegated to audit account&#xa;• Findings → Security Hub" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="126" width="210" height="175" as="geometry" />
        </mxCell>
        <mxCell id="p2-config" value="&lt;b&gt;module.config_rules&lt;/b&gt;&#xa;AWS Config + Aggregator  ← new&#xa;─────────────────&#xa;• FORGE-S3-001: public access&#xa;• FORGE-IAM-003: MFA users&#xa;• FORGE-EC2-001: EBS encrypt&#xa;• FORGE-EC2-003: SG wildcards&#xa;• FORGE-RDS-001: RDS encrypt&#xa;• Config Aggregator (all-regions)&#xa;• org aggregation role (IAM)&#xa;• Single-pane compliance view" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="755" y="126" width="250" height="175" as="geometry" />
        </mxCell>

        <!-- WAFv2 + SHIELD LAYER  y=425, h=200 -->
        <mxCell id="p2-waf-band" value="WAFv2 + SHIELD LAYER  ← new in growth-stage" style="swimlane;startSize=28;fillColor=#f0e6ff;strokeColor=#7b5ea7;fontStyle=1;fontSize=11;fontColor=#2d0047;" vertex="1" parent="1">
          <mxGeometry x="60" y="425" width="1130" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p2-wafacl" value="&lt;b&gt;aws_wafv2_web_acl.regional&lt;/b&gt;&#xa;WAFv2 Regional WebACL&#xa;─────────────────&#xa;Priority 10: AWSManagedRulesCommonRuleSet&#xa;&amp;nbsp;&amp;nbsp;(OWASP Top 10 core protection)&#xa;Priority 20: KnownBadInputsRuleSet&#xa;&amp;nbsp;&amp;nbsp;(Log4j, Spring4Shell, etc.)&#xa;Priority 30: AWSManagedRulesSQLiRuleSet&#xa;&amp;nbsp;&amp;nbsp;(SQL injection protection)&#xa;CloudWatch metrics + sampled requests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7b5ea7;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="462" width="355" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p2-shield" value="&lt;b&gt;AWS Shield Standard&lt;/b&gt;&#xa;DDoS Protection&#xa;─────────────────&#xa;• Automatic on all ALBs&#xa;• L3/L4 volumetric attacks&#xa;• SYN/UDP flood protection&#xa;• No additional cost&#xa;• CloudFront + Route 53 covered" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7b5ea7;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="445" y="462" width="220" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p2-wafalb" value="&lt;b&gt;aws_wafv2_web_acl_association.alb&lt;/b&gt;&#xa;WAF → ALB Association&#xa;─────────────────&#xa;• Associates WebACL to ALB ARN&#xa;• Conditional on waf_alb_arn var&#xa;• Internet-facing ALBs protected&#xa;• REGIONAL scope WebACL&#xa;• CloudFront: CLOUDFRONT scope" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7b5ea7;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="462" width="240" height="150" as="geometry" />
        </mxCell>

        <!-- MACIE LAYER  y=635, h=175 -->
        <mxCell id="p2-macie-band" value="AMAZON MACIE LAYER  ← new in growth-stage · HIPAA §164.312(a)(2)(iv)" style="swimlane;startSize=28;fillColor=#fce4ec;strokeColor=#c62828;fontStyle=1;fontSize=11;fontColor=#4d0000;" vertex="1" parent="1">
          <mxGeometry x="60" y="635" width="1130" height="175" as="geometry" />
        </mxCell>
        <mxCell id="p2-macie-acct" value="&lt;b&gt;aws_macie2_account.this&lt;/b&gt;&#xa;Macie Account Activation&#xa;─────────────────&#xa;• enable_macie = true&#xa;• Status: ENABLED&#xa;• Finding frequency: ONE_HOUR&#xa;• Configurable: 15min/1hr/6hr&#xa;• Conditional on var.enable_macie" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="672" width="245" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p2-macie-job" value="&lt;b&gt;aws_macie2_classification_job.s3_full_scan&lt;/b&gt;&#xa;Sensitive Data Discovery Job&#xa;─────────────────&#xa;• Type: SCHEDULED (weekly)&#xa;• Schedule: MONDAY&#xa;• Scans: log_archive_bucket&#xa;• Discovers: PII · PCI · PHI&#xa;• Findings → Macie console" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="335" y="672" width="285" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p2-macie-findings" value="Macie Findings&#xa;─────────────────&#xa;• S3 object classification&#xa;• Unencrypted sensitive data&#xa;• Overly permissive bucket ACLs&#xa;• Anomalous access patterns&#xa;• Feeds into Security Hub&#xa;  (HIPAA evidence)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="635" y="672" width="250" height="120" as="geometry" />
        </mxCell>

        <!-- ==========================================================
             RIGHT COLUMN (x=1210, w=650)
        ========================================================== -->

        <!-- DRIFT REMEDIATION LAYER  y=90, h=545 -->
        <mxCell id="p2-rem-band" value="DRIFT REMEDIATION LAYER  (Event-Driven Lambda)" style="swimlane;startSize=40;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;fontColor=#4d2600;" vertex="1" parent="1">
          <mxGeometry x="1210" y="90" width="650" height="545" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-trigger" value="Trigger: Config NON_COMPLIANT → EventBridge Rule → Lambda (Python 3.12 · X-Ray active tracing)" style="text;html=1;strokeColor=none;fillColor=#ffe6cc;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1218" y="135" width="634" height="18" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-s3" value="&lt;b&gt;module.remediate_s3&lt;/b&gt;&#xa;S3 Block Public Access&#xa;Rule: FORGE-S3-001&#xa;Fix: PutBucketPublicAccessBlock&#xa;(all 4 flags = true, idempotent)&#xa;Controls: NIST AC-3, SC-7 · SOC2 CC6.1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1218" y="160" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-mfa" value="&lt;b&gt;module.remediate_mfa&lt;/b&gt;&#xa;IAM MFA Gap Remediation&#xa;Rule: FORGE-IAM-003&#xa;Fix: DeleteLoginProfile (no MFA user)&#xa;(console access revoked until enrolled)&#xa;Controls: NIST IA-2 · SOC2 CC6.1 · FFIEC IS.10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1532" y="160" width="310" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-ebs" value="&lt;b&gt;module.remediate_ebs&lt;/b&gt;&#xa;EBS Encryption by Default&#xa;Rule: FORGE-EC2-001&#xa;Fix: EnableEbsEncryptionByDefault&#xa;(account-level flag, new volumes only)&#xa;Controls: NIST SC-28 · SOC2 CC6.7 · HIPAA 164.312" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1218" y="262" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-sg" value="&lt;b&gt;module.remediate_sg&lt;/b&gt;&#xa;Remove SG Wildcard Rules&#xa;Rule: FORGE-EC2-003&#xa;Fix: RevokeSecurityGroupIngress&#xa;Ports: 22·3306·3389·5432·1433+&#xa;Controls: NIST SC-7, AC-4 · SOC2 CC6.6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1532" y="262" width="310" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-rds" value="&lt;b&gt;module.remediate_rds&lt;/b&gt; (human-in-loop · not auto-remediated)&#xa;RDS Encryption Alert · Rule: FORGE-RDS-001&#xa;Action: SNS alert + runbook link (automated snapshot-restore would cause destructive downtime)&#xa;Controls: NIST SC-28 · HIPAA §164.312(a)(2)(iv) · SOC2 CC6.7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;strokeDashArray=4 2;" vertex="1" parent="1">
          <mxGeometry x="1218" y="364" width="624" height="75" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-arch" value="Lambda Architecture Notes&#xa;────────────────────────────────────────────────────&#xa;Runtime: Python 3.12 · Tracing: AWS X-Ray active&#xa;IAM: least-privilege execution role per function&#xa;Idempotent: checks current state before acting&#xa;Observability: CloudWatch CW Error Alarms + structured audit log&#xa;Config Aggregator: org-wide view of all rule violations" style="text;html=1;strokeColor=#d79b00;fillColor=#fff3e0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=9;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1218" y="451" width="624" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-note" value="All 5 remediators wired to module.guardduty.alerts_topic_arn · same SNS topic as GuardDuty security alerts" style="text;html=1;strokeColor=none;fillColor=#ffe6cc;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1218" y="558" width="634" height="18" as="geometry" />
        </mxCell>

        <!-- Dual-Standard Controls Table  y=645, h=175 -->
        <mxCell id="p2-dual-controls" value="Dual-Standard Compliance Evidence&#xa;─────────────────────────────────────────────────────────&#xa;SOC 2 Type II CC6.1  IAM MFA enforcement + SCIM provisioning&#xa;SOC 2 Type II CC6.6  SG wildcard removal (auto-remediated)&#xa;SOC 2 Type II CC6.7  EBS + RDS encryption controls&#xa;SOC 2 Type II CC7.1  GuardDuty + Security Hub threat detection&#xa;HIPAA §164.312(a)    EBS/RDS encryption at rest (KMS CMK)&#xa;HIPAA §164.312(d)    MFA enforcement (SCP + IAM policy)&#xa;HIPAA §164.312(e)    TLS 1.2+ in transit + S3 deny-HTTP&#xa;HIPAA §164.308       Macie PII/PHI discovery + audit trail&#xa;NIST AC-4 / SC-7     WAFv2 OWASP + SG wildcard controls" style="text;html=1;strokeColor=#b85450;fillColor=#fff0f0;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=9;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1210" y="645" width="650" height="185" as="geometry" />
        </mxCell>

        <!-- WAFv2 + Shield note  y=840, h=150 -->
        <mxCell id="p2-waf-note" value="Internet Traffic Flow&#xa;──────────────────────────────────────────────────────────────────&#xa;Internet → Route 53 (DNS) → CloudFront → WAFv2 WebACL (CLOUDFRONT scope)&#xa;Internet → ALB → WAFv2 WebACL (REGIONAL scope) → App tier subnets&#xa;Shield Standard: always-on at Route 53 + CloudFront + ALB + EIP&#xa;WAF blocks: SQLi · XSS · Log4j · Spring4Shell · known-bad-IPs&#xa;All blocked requests logged to CloudWatch (sampled + full metrics)" style="text;html=1;strokeColor=#7b5ea7;fillColor=#f0e6ff;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=9;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1210" y="840" width="650" height="150" as="geometry" />
        </mxCell>

        <!-- ==========================================================
             EDGES — PAGE 2
        ========================================================== -->
        <mxCell id="p2-e-gd-sh"      style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b85450;" edge="1" parent="1" source="p2-gd"       target="p2-sh"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-ins-sh"     style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b85450;" edge="1" parent="1" source="p2-inspector" target="p2-sh"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-macie-sh"   value="findings" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#c62828;strokeDashArray=4 2;fontSize=9;" edge="1" parent="1" source="p2-macie-findings" target="p2-sh"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-waf-alb"    style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#7b5ea7;" edge="1" parent="1" source="p2-wafacl"    target="p2-wafalb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-macie-job"  style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#c62828;" edge="1" parent="1" source="p2-macie-acct" target="p2-macie-job"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-job-find"   style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#c62828;" edge="1" parent="1" source="p2-macie-job" target="p2-macie-findings"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-config-rem" value="NON_COMPLIANT event" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#d79b00;strokeWidth=2;fontStyle=2;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-config" target="p2-rem-band"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>

