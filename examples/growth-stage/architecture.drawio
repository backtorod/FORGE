        <mxCell id="p1-mod-org" value="&lt;b&gt;module.organization&lt;/b&gt;&#xa;AWS Organizations&#xa;─────────────────&#xa;• Management account&#xa;• OU: Workloads/Prod&#xa;• OU: Workloads/NonProd  ← new&#xa;• Log Archive account&#xa;• Audit account&#xa;• Network account&#xa;• Shared Services account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="126" width="215" height="155" as="geometry" />
        </mxCell>
        <mxCell id="p1-mod-scp" value="&lt;b&gt;module.scp&lt;/b&gt;&#xa;Service Control Policies&#xa;─────────────────&#xa;• Deny non-approved regions&#xa;• Enforce encryption at rest&#xa;• Block root account actions&#xa;• Prevent CloudTrail disable&#xa;• Applied to: Prod OU&#xa;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;+ NonProd OU  ← new" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="305" y="126" width="215" height="155" as="geometry" />
        </mxCell>
        <mxCell id="p1-mod-logging" value="&lt;b&gt;module.logging&lt;/b&gt;&#xa;Centralized Logging&#xa;─────────────────&#xa;• CloudTrail (org-wide, KMS)&#xa;• VPC Flow Logs (both regions)&#xa;• S3 Access Logs&#xa;• CloudWatch Log Groups&#xa;• Immutable S3 log bucket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="535" y="126" width="215" height="155" as="geometry" />
        </mxCell>
