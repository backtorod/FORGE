        <mxCell id="p1-e-secvpc-log"  value="flow logs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#82b366;strokeDashArray=4 2;fontSize=9;" edge="1" parent="1" source="p1-vpc-sec" target="p1-mod-logging"><mxGeometry relative="1" as="geometry" /></mxCell>
