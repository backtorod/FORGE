        <mxCell id="p1-e-log-kms"     style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#6c8ebf;" edge="1" parent="1" source="p1-mod-logging" target="p1-mod-kms"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p1-e-vpc-tgw"     style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#82b366;" edge="1" parent="1" source="p1-vpc-pri"  target="p1-tgw"><mxGeometry relative="1" as="geometry" /></mxCell>
