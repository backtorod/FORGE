        <mxCell id="mod-org" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=10;" value="&lt;b&gt;module.organization&lt;/b&gt;&#xa;AWS Organizations&#xa;─────────────────&#xa;• Management account&#xa;• OU: Workloads / Prod&#xa;• Log Archive account&#xa;• Audit account&#xa;• Network account&#xa;• Shared Services account" vertex="1">
          <mxGeometry height="135" width="215" x="75" y="136" as="geometry" />
        </mxCell>
        <mxCell id="mod-scp" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=10;" value="&lt;b&gt;module.scp&lt;/b&gt;&#xa;Service Control Policies&#xa;─────────────────&#xa;• Deny non-approved regions&#xa;• Enforce encryption at rest&#xa;• Block root account actions&#xa;• Prevent CloudTrail disable&#xa;• Restrict high-risk services" vertex="1">
          <mxGeometry height="135" width="215" x="305" y="136" as="geometry" />
        </mxCell>
