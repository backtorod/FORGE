          <mxGeometry x="75" y="348" width="195" height="185" as="geometry" />
        </mxCell>
        <mxCell id="p1-vpc-sec" value="&lt;b&gt;module.vpc_secondary&lt;/b&gt;&#xa;Secondary VPC · us-west-2&#xa;10.1.0.0/16 · 3 AZs&#xa;─────────────────&#xa;• Public (ALB tier)&#xa;• Private App&#xa;• Private Data&#xa;• provider = aws.secondary&#xa;• VPC Flow Logs → S3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=10;strokeDashArray=6 3;strokeWidth=2;" vertex="1" parent="1">
