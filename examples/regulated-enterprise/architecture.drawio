        <!-- Enterprise enhancements callout  y=860, h=177 -->
        <mxCell id="p1-enhancements" value="Enterprise Enhancements vs Growth-Stage&#xa;────────────────────────────────────────────────────────────────&#xa;✦ AWS Network Firewall: stateful east-west + north-south inspection&#xa;    Dedicated /28 firewall subnets · STRICT_ORDER rule evaluation&#xa;    Flow + Alert logs to CloudWatch (KMS, 365-day retention)&#xa;✦ AWS Audit Manager: FORGE custom framework (see Page 2)&#xa;✦ AWS Backup: Vault Lock (WORM) + cross-region copy (see Page 2)&#xa;✦ SIEM EventBridge bus: GuardDuty ≥7 severity → Splunk/Sentinel (Page 2)&#xa;✦ NIST 800-53 Rev 5 conformance pack: access-keys-rotated (90d)&#xa;✦ Compliance tags: FFIEC CAT · HIPAA · FedRAMP Moderate · HITRUST CSF&#xa;✦ Macie frequency: FIFTEEN_MINUTES (vs ONE_HOUR in growth-stage)" style="text;html=1;strokeColor=#d79b00;fillColor=#fffde7;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=10;rounded=1;" vertex="1" parent="1">
