        <!-- DRIFT REMEDIATION  y=90, h=490 -->
        <mxCell id="p2-rem-band" value="DRIFT REMEDIATION LAYER  (Event-Driven Lambda)" style="swimlane;startSize=40;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;fontColor=#4d2600;" vertex="1" parent="1">
          <mxGeometry x="1210" y="90" width="650" height="490" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-trigger" value="Trigger: Config NON_COMPLIANT → EventBridge Rule → Lambda (Python 3.12 · X-Ray active tracing)" style="text;html=1;strokeColor=none;fillColor=#ffe6cc;align=center;fontSize=9;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1218" y="137" width="634" height="16" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-s3" value="&lt;b&gt;module.remediate_s3&lt;/b&gt;&#xa;S3 Block Public Access&#xa;Rule: FORGE-S3-001&#xa;Fix: PutBucketPublicAccessBlock (×4 flags)&#xa;Controls: NIST AC-3, SC-7 · SOC2 CC6.1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1218" y="160" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-mfa" value="&lt;b&gt;module.remediate_mfa&lt;/b&gt;&#xa;IAM MFA Gap Remediation&#xa;Rule: FORGE-IAM-003&#xa;Fix: DeleteLoginProfile (no-MFA user)&#xa;Controls: NIST IA-2 · FFIEC IS.10 · SOC2 CC6.1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1532" y="160" width="310" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-ebs" value="&lt;b&gt;module.remediate_ebs&lt;/b&gt;&#xa;EBS Encryption by Default&#xa;Rule: FORGE-EC2-001&#xa;Fix: EnableEbsEncryptionByDefault&#xa;Controls: NIST SC-28 · HIPAA §164.312 · SOC2 CC6.7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1218" y="252" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-sg" value="&lt;b&gt;module.remediate_sg&lt;/b&gt;&#xa;Remove SG Wildcard Rules&#xa;Rule: FORGE-EC2-003&#xa;Fix: RevokeSecurityGroupIngress&#xa;Ports: 22·3306·3389·5432·27017+&#xa;Controls: NIST SC-7, AC-4 · SOC2 CC6.6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1532" y="252" width="310" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-rds" value="&lt;b&gt;module.remediate_rds&lt;/b&gt; (human-in-loop · alert_topic_arn wired to GuardDuty SNS)&#xa;RDS Encryption Alert · Rule: FORGE-RDS-001 · Action: SNS + runbook link (snapshot-restore = manual)&#xa;Controls: NIST SC-28 · HIPAA §164.312(a)(2)(iv) · SOC2 CC6.7 · FFIEC IS.10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=6;fontSize=9;strokeDashArray=4 2;" vertex="1" parent="1">
          <mxGeometry x="1218" y="354" width="624" height="68" as="geometry" />
        </mxCell>
        <mxCell id="p2-rem-notes" value="Infrastructure Notes&#xa;──────────────────────────────────────────────────────────────&#xa;• Runtime: Python 3.12 · Tracing: X-Ray active · Memory: 256 MB&#xa;• IAM: least-privilege execution role per function (separate in enterprise)&#xa;• Idempotent: checks current state before acting on every invocation&#xa;• CloudWatch CW Error Alarms → same SNS topic as GuardDuty&#xa;• Config Aggregator: enterprise has org-wide all-region view&#xa;• audit_topic_arn: module.guardduty.alerts_topic_arn (no separate topic)" style="text;html=1;strokeColor=#d79b00;fillColor=#fff3e0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=9;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1218" y="433" width="624" height="130" as="geometry" />
        </mxCell>

        <!-- Compliance Evidence Table  y=590, h=250 -->
        <mxCell id="p2-compliance" value="Multi-Framework Compliance Evidence Map&#xa;──────────────────────────────────────────────────────────────────&#xa;FFIEC CAT IS.10    SG wildcard auto-remediation · WAFv2 OWASP · Network Firewall&#xa;FFIEC CAT IS.11    MFA enforcement SCP · IAM Access Analyzer · SCIM provisioning&#xa;HIPAA §164.308     Audit Manager evidence · Macie PHI discovery · audit trail&#xa;HIPAA §164.312(a)  EBS + RDS encryption (KMS CMK) · Backup Vault Lock (WORM)&#xa;HIPAA §164.312(d)  MFA SCP + IAM baseline · break-glass MFA required&#xa;HIPAA §164.312(e)  TLS 1.2+ + ACM cert · S3 deny-HTTP · ALB HTTPS-only&#xa;FedRAMP Moderate   NIST 800-53 Rev5 conformance pack · Config access-keys-rotated&#xa;HITRUST CSF        Inherited controls via FORGE layer + AWS shared responsibility&#xa;SOC 2 CC6.1–CC7.2  GuardDuty + Security Hub + Inspector + all FORGE Config rules" style="text;html=1;strokeColor=#b85450;fillColor=#fff0f0;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=9;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1210" y="590" width="650" height="220" as="geometry" />
        </mxCell>

        <!-- SIEM Data Flow note  y=820, h=215 -->
        <mxCell id="p2-siem-flow" value="SIEM Ingestion Data Flow&#xa;──────────────────────────────────────────────────────────────────&#xa;GuardDuty finding (severity ≥ 7)&#xa;  → EventBridge rule (aws.guardduty · default bus)&#xa;  → EventBridge target (events-to-siem-role · PutEvents)&#xa;  → SIEM custom event bus (org-scoped policy)&#xa;  → External SIEM connector (Splunk / Microsoft Sentinel / Sumo Logic)&#xa;&#xa;All member accounts can putEvents directly to SIEM bus&#xa;(aws:PrincipalOrgID condition on bus resource policy)&#xa;&#xa;Backup Cross-Region Copy Flow&#xa;  Daily 05:00 UTC → primary vault → copy_action → secondary vault (us-west-2)&#xa;  Cold storage after 30d · Delete after 90d (daily) / 365d (weekly)" style="text;html=1;strokeColor=#274e13;fillColor=#d9ead3;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=9;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1210" y="820" width="650" height="230" as="geometry" />
        </mxCell>

        <!-- ================================================================
             EDGES — PAGE 2
        ================================================================ -->
        <mxCell id="p2-e-gd-sh"     style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b85450;" edge="1" parent="1" source="p2-gd"       target="p2-sh"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-ins-sh"    style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b85450;" edge="1" parent="1" source="p2-inspector" target="p2-sh"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-gd-siem"   value="severity ≥ 7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#274e13;strokeWidth=2;fontSize=9;" edge="1" parent="1" source="p2-gd" target="p2-siem-rule"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-rule-bus"  style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#274e13;strokeWidth=2;" edge="1" parent="1" source="p2-siem-rule" target="p2-siem-bus"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-am-ctrl"   style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1155cc;" edge="1" parent="1" source="p2-am-framework" target="p2-am-assessment"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-am-config" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#1155cc;strokeDashArray=4 2;" edge="1" parent="1" source="p2-config" target="p2-am-framework"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-vlt-plan"  style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#bf8a00;" edge="1" parent="1" source="p2-vault-pri" target="p2-backup-plan"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-plan-sec"  value="cross-region copy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#bf8a00;strokeDashArray=4 2;fontSize=9;strokeWidth=2;" edge="1" parent="1" source="p2-backup-plan" target="p2-vault-sec"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-e-config-rem" value="NON_COMPLIANT" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#d79b00;strokeWidth=2;fontStyle=2;fontSize=9;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="p2-config" target="p2-rem-band"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
