        <!-- AUDIT MANAGER LAYER  y=400, h=215 -->
        <mxCell id="p2-audit-band" value="AWS AUDIT MANAGER LAYER  ← new in enterprise" style="swimlane;startSize=28;fillColor=#cfe2f3;strokeColor=#1155cc;fontStyle=1;fontSize=11;fontColor=#0b2d6e;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="1130" height="215" as="geometry" />
        </mxCell>
        <mxCell id="p2-am-framework" value="&lt;b&gt;aws_auditmanager_framework.forge&lt;/b&gt;&#xa;FORGE Custom Framework&#xa;─────────────────&#xa;Name: FORGE-HIPAA-FFIEC-CAT&#xa;Control Set: Access-Control&#xa;  • IAM-MFA-Required&#xa;  • Access-Key-Rotation-90-Days&#xa;Control Set: Data-Protection&#xa;  • S3-Server-Side-Encryption&#xa;  • RDS-Storage-Encrypted&#xa;Source: AWS Config rule mappings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#1155cc;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="438" width="270" height="162" as="geometry" />
        </mxCell>
        <mxCell id="p2-am-assessment" value="&lt;b&gt;aws_auditmanager_assessment.forge&lt;/b&gt;&#xa;FORGE Assessment&#xa;─────────────────&#xa;• Role: PROCESS_OWNER&#xa;  (auditmanager.amazonaws.com)&#xa;• Services in scope:&#xa;  S3 · IAM · RDS · GuardDuty&#xa;• Reports destination:&#xa;  s3://log-archive/audit-manager/&#xa;• Continuous evidence collection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#1155cc;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="438" width="265" height="162" as="geometry" />
        </mxCell>
        <mxCell id="p2-am-controls" value="Audit Controls Mapped to Config Rules&#xa;─────────────────────────────────────────&#xa;IAM-MFA-Required&#xa;  → Config: MFA_ENABLED_FOR_IAM_CONSOLE_ACCESS&#xa;Access-Key-Rotation-90-Days&#xa;  → Config: ACCESS_KEYS_ROTATED&#xa;S3-Server-Side-Encryption&#xa;  → Config: S3_DEFAULT_ENCRYPTION_KMS&#xa;RDS-Storage-Encrypted&#xa;  → Config: RDS_STORAGE_ENCRYPTED" style="text;html=1;strokeColor=#1155cc;fillColor=#e8f0fe;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=9;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="438" width="385" height="162" as="geometry" />
        </mxCell>

        <!-- BACKUP LAYER  y=625, h=215 -->
        <mxCell id="p2-backup-band" value="AWS BACKUP LAYER — Vault Lock (WORM) + Cross-Region Copy  ← new in enterprise" style="swimlane;startSize=28;fillColor=#fef0cd;strokeColor=#bf8a00;fontStyle=1;fontSize=11;fontColor=#4d3600;" vertex="1" parent="1">
          <mxGeometry x="60" y="625" width="1130" height="215" as="geometry" />
        </mxCell>
        <mxCell id="p2-vault-pri" value="&lt;b&gt;aws_backup_vault.primary&lt;/b&gt;&#xa;Primary Backup Vault · us-east-1&#xa;─────────────────&#xa;• KMS key: rds_key_arn&#xa;• Vault Lock (WORM) enabled&#xa;  min_retention: 7 days&#xa;  max_retention: 3650 days (10 yr)&#xa;  changeable_for_days: 3&#xa;• After 3 days: IMMUTABLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef0cd;strokeColor=#bf8a00;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="663" width="245" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p2-vault-sec" value="&lt;b&gt;aws_backup_vault.secondary&lt;/b&gt;&#xa;Secondary Backup Vault · us-west-2&#xa;─────────────────&#xa;• provider = aws.secondary&#xa;• KMS key: rds_key_arn&#xa;• Receives cross-region copies&#xa;• Daily + weekly cross-copy&#xa;• Disaster recovery target" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef0cd;strokeColor=#bf8a00;align=left;spacingLeft=8;fontSize=10;strokeDashArray=6 3;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="335" y="663" width="245" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p2-backup-plan" value="&lt;b&gt;aws_backup_plan.main&lt;/b&gt;&#xa;Backup Plan&#xa;─────────────────&#xa;Daily Rule (05:00 UTC):&#xa;  • Cold storage after: 30 days&#xa;  • Delete after: 90 days&#xa;  • Cross-region copy → secondary&#xa;Weekly Rule (Sun 06:00 UTC):&#xa;  • Cold storage after: 30 days&#xa;  • Delete after: 365 days&#xa;Role: AWSBackupServiceRolePolicy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef0cd;strokeColor=#bf8a00;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="595" y="663" width="280" height="160" as="geometry" />
        </mxCell>

        <!-- SIEM LAYER  y=850, h=185 -->
        <mxCell id="p2-siem-band" value="SIEM INGESTION LAYER — Cross-Account EventBridge Bus  ← new in enterprise" style="swimlane;startSize=28;fillColor=#d9ead3;strokeColor=#274e13;fontStyle=1;fontSize=11;fontColor=#1a3d00;" vertex="1" parent="1">
          <mxGeometry x="60" y="850" width="1130" height="185" as="geometry" />
        </mxCell>
        <mxCell id="p2-siem-bus" value="&lt;b&gt;aws_cloudwatch_event_bus.siem&lt;/b&gt;&#xa;SIEM Event Bus&#xa;─────────────────&#xa;• Custom cross-account bus&#xa;• Policy: allow aws:PrincipalOrgID&#xa;  (all Org accounts can putEvents)&#xa;• Targets: Splunk · Sentinel · Sumo&#xa;• Conditional on enable_siem_event_bus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#274e13;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="887" width="260" height="135" as="geometry" />
        </mxCell>
        <mxCell id="p2-siem-rule" value="&lt;b&gt;aws_cloudwatch_event_rule.guardduty_high_severity&lt;/b&gt;&#xa;GuardDuty → SIEM Rule&#xa;─────────────────&#xa;• Source: aws.guardduty&#xa;• detail-type: GuardDuty Finding&#xa;• Filter: severity ≥ 7&#xa;• Event bus: default&#xa;• Role: events-to-siem-role" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#274e13;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="887" width="280" height="135" as="geometry" />
        </mxCell>
        <mxCell id="p2-siem-target" value="WAFv2 (inherited)&#xa;─────────────────&#xa;• Regional WebACL (enterprise)&#xa;Priority 10: CommonRuleSet&#xa;Priority 20: KnownBadInputs&#xa;Priority 30: SQLiRuleSet&#xa;• ALB association (conditional)&#xa;• CloudWatch metrics + sampling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0e6ff;strokeColor=#7b5ea7;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="645" y="887" width="250" height="135" as="geometry" />
        </mxCell>

