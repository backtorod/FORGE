        <mxCell id="p1-mod-org" value="&lt;b&gt;module.organization&lt;/b&gt;&#xa;AWS Organizations&#xa;─────────────────&#xa;• Management account&#xa;• OU: Workloads/Prod&#xa;• OU: Workloads/NonProd&#xa;• Log Archive account&#xa;• Audit account&#xa;• Network account&#xa;• Shared Services account" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="75" y="126" width="210" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p1-mod-scp" value="&lt;b&gt;module.scp&lt;/b&gt;&#xa;Service Control Policies&#xa;─────────────────&#xa;• Deny non-approved regions&#xa;• Enforce encryption at rest&#xa;• Block root account actions&#xa;• Prevent CloudTrail disable&#xa;• Applied: Prod + NonProd OUs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="126" width="210" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p1-mod-logging" value="&lt;b&gt;module.logging&lt;/b&gt;&#xa;Centralized Logging&#xa;─────────────────&#xa;• CloudTrail (org-wide, KMS)&#xa;• VPC Flow Logs (both regions)&#xa;• Network Firewall flow + alert&#xa;• S3 Access Logs&#xa;• Immutable S3 log bucket&#xa;• Firewall logs: 365 days" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="525" y="126" width="215" height="160" as="geometry" />
        </mxCell>
        <mxCell id="p1-mod-kms" value="&lt;b&gt;module.kms&lt;/b&gt;&#xa;KMS Customer Managed Keys&#xa;─────────────────&#xa;• cloudtrail key&#xa;• s3_logs · guardduty · sns&#xa;• rds key · ebs key&#xa;• secrets · identity_center&#xa;• Firewall CW logs: KMS&#xa;• Backup vault: rds_key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;fontSize=10;" vertex="1" parent="1">
